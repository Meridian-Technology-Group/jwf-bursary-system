# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Prisma)
# Transaction pooler for runtime queries (port 6543)
DATABASE_URL=postgresql://postgres.your-project:password@aws-1-eu-west-2.pooler.supabase.com:6543/postgres
# Session pooler for migrations (port 5432)
DIRECT_URL=postgresql://postgres.your-project:password@aws-1-eu-west-2.pooler.supabase.com:5432/postgres

# Resend (email)
RESEND_API_KEY=re_your-api-key
RESEND_FROM_EMAIL=bursary@yourdomain.com
# Svix signing secret from Resend dashboard → Webhooks → Signing Secret
# Required for the /api/webhooks/resend handler to accept events.
RESEND_WEBHOOK_SECRET=whsec_your-signing-secret

# Vercel (deployment)
VERCEL_PROJECT_ID=prj_your-project-id
VERCEL_TEAM_ID=

# Auth rate limiting is handled at the edge by Vercel WAF (fixed-window rule
# on the /login and /reset-password paths), configured in vercel.json — not via
# application code or env vars. No KV/Upstash store or keys are required.
# See docs/operations/environment-variables.md and the Vercel WAF docs.

# App
# Public base URL of the deployment (used to build links in emails). Falls back
# to the Vercel-provided URL if unset, but set it explicitly in production.
NEXT_PUBLIC_APP_URL=https://your-domain.org
# Supabase Storage bucket for uploaded documents (defaults to "documents").
SUPABASE_STORAGE_BUCKET=documents
# Staff MFA enforcement. Prod enforces by default (VERCEL_ENV=production);
# set to "true" to force-enable in staging/local, "false" as a prod kill-switch.
STAFF_MFA_ENFORCED=

# Sentry (error monitoring). When the DSN is unset, the SDK is a no-op, so
# local dev and CI never send events. Set these in the Vercel envs.
# DSN: Sentry dashboard → Settings → Projects → <project> → Client Keys (DSN).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Source-map upload at build time (Production/Preview builds only).
# Auth token: Sentry → Settings → Auth Tokens (scope: project:releases).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
