# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Prisma)
# Transaction pooler for runtime queries (port 6543)
DATABASE_URL=postgresql://postgres.your-project:password@aws-1-eu-west-2.pooler.supabase.com:6543/postgres
# Session pooler for migrations (port 5432)
DIRECT_URL=postgresql://postgres.your-project:password@aws-1-eu-west-2.pooler.supabase.com:5432/postgres

# Resend (email)
RESEND_API_KEY=re_your-api-key
RESEND_FROM_EMAIL=bursary@yourdomain.com

# Vercel (deployment)
VERCEL_PROJECT_ID=prj_your-project-id
VERCEL_TEAM_ID=
